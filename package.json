{
  "name": "@wonsukchoi/crondex",
  "version": "0.71.0",
  "description": "A public directory of pre-made, agent-editable cron jobs — usable as a CLI or as an MCP server.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wonsukchoi/crondex.git"
  },
  "homepage": "https://github.com/wonsukchoi/crondex",
  "keywords": [
    "cron",
    "cron-jobs",
    "ai-agent",
    "claude",
    "codex",
    "automation",
    "scheduler",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "llm"
  ],
  "bin": {
    "crondex": "bin/crondex.js"
  },
  "files": [
    "bin",
    "lib",
    "jobs",
    "schema",
    "templates",
    "catalog.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build-catalog": "node scripts/build-catalog.js",
    "build-site": "node scripts/build-site.js",
    "validate": "node scripts/validate-jobs.js",
    "lint-shell": "node scripts/lint-shell.js",
    "check-duplicates": "node scripts/check-duplicates.js",
    "check-category-floor": "node scripts/check-category-floor.js",
    "verify-deploy-artifacts": "node scripts/verify-deploy-artifacts.js",
    "smoke-test": "node scripts/smoke-test.js",
    "test": "node --test test/*.test.js",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "js-yaml": "^4.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "ajv": "^8.17.1"
  }
}
